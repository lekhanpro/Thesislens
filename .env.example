# ──────────────────────────────────────────────
# ThesisLens — Environment Variables Template
# Copy this to .env.local for local dev
# On Vercel, set these in Project Settings → Environment Variables
# ──────────────────────────────────────────────

# ── Groq LLM (REQUIRED) ──────────────────────
# Get your key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Tavily Web Search (OPTIONAL but recommended) ──
# Get your key from: https://app.tavily.com
# Powers the "Search References" feature with real academic web results
# Without this, the app shows fallback links to arXiv / Semantic Scholar
TAVILY_API_KEY=tvly-your_tavily_key_here

# ── Vercel Blob (OPTIONAL — needed for production PDF storage) ──
# Created automatically when you add Blob in Vercel dashboard Storage tab
BLOB_READ_WRITE_TOKEN=

# ── Vercel KV (OPTIONAL — needed for production data persistence) ──
# Created automatically when you add KV in Vercel dashboard Storage tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
